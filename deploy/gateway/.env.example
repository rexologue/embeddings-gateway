# Copy this file to .env and adjust values for the host.

GATEWAY_HOST=0.0.0.0
GATEWAY_HTTP_PORT=11000
GATEWAY_PROMETHEUS_HTTP_PORT=11100
GATEWAY_LOKI_HTTP_PORT=11102

GATEWAY_CONTAINER_NAME=embeddings-gateway
GATEWAY_BACKEND_BASE_URL=http://host.docker.gateway:11010

GATEWAY_TIMEOUT_CONNECT_SEC=30
GATEWAY_TIMEOUT_READ_SEC=300
GATEWAY_TIMEOUT_WRITE_SEC=300
GATEWAY_TIMEOUT_POOL_SEC=30
GATEWAY_HTTP_MAX_CONNECTIONS=200
GATEWAY_HTTP_MAX_KEEPALIVE_CONNECTIONS=100

GATEWAY_PROMETHEUS_IMAGE=prom/prometheus:latest
GATEWAY_PROMETHEUS_CONTAINER_NAME=embeddings-gateway-prometheus

GATEWAY_LOKI_IMAGE=grafana/loki:3.7.1
GATEWAY_LOKI_CONTAINER_NAME=embeddings-gateway-loki
GATEWAY_LOKI_APP_NAME=embeddings-gateway
GATEWAY_LOKI_ENABLED=true
GATEWAY_LOKI_PUSH_URL=http://embeddings-gateway-loki:3100/loki/api/v1/push
GATEWAY_LOKI_BATCH_SIZE=200
GATEWAY_LOKI_FLUSH_INTERVAL_SEC=1.0
GATEWAY_LOKI_QUEUE_MAX_SIZE=10000
