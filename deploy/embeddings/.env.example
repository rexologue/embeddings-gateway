# Copy this file to .env and adjust values for the host.

EMBEDDINGS_HOST=0.0.0.0
EMBEDDINGS_HTTP_PORT=11010
EMBEDDINGS_PROMETHEUS_HTTP_PORT=11101

EMBEDDINGS_VLLM_IMAGE=vllm/vllm-openai:v0.19.0
EMBEDDINGS_CONTAINER_NAME=embeddings-vllm
EMBEDDINGS_PROMETHEUS_IMAGE=prom/prometheus:latest
EMBEDDINGS_PROMETHEUS_CONTAINER_NAME=embeddings-vllm-prometheus

EMBEDDINGS_MODEL_PATH=/root/.models/Qwen3-Embedding-0.6B
EMBEDDINGS_MODEL_MOUNT=/model
EMBEDDINGS_SERVED_MODEL_NAME=embeddings-model

CUDA_VISIBLE_DEVICES=1
